# Color scheme symlinks
theme.conf
theme.css
colors.ini
theme.lua

# Theme directories
# Files in these directories are generated by mde
themes/
colors/

# Symlinks for machine-specific configs
# (E.g., monitors, peripherals, etc.)
inputs.conf
outputs.conf
bar.conf
# I added a layer of indirection using a pattern involving setting
# configs with basename `current`
# It's not clear that this is actually helping things, so this may
# eventually just go away
current.*
# Waybar top bar
top.jsonc
