#!/bin/bash

if [[ ${#@} -eq 0 ]]; then
  echo "No command specified!"
  exit 1
fi

declare -r cmd_name="$1"
shift

declare -r MDE_LIB_DIR="${HOME}/.local/lib/mde"

declare -r cmd="${MDE_LIB_DIR}/commands/${cmd_name}.sh"

if [ ! -x "$cmd" ]; then
  echo "No such command!"
  exit 1
fi

# shellcheck disable=1090
. "$cmd" "${@}"

exit 0
