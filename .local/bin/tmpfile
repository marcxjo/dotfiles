#!/usr/bin/env bash

declare USER_TMP_DIR TMP_FILE_DATE TMP_FILE_PATH TMP_FILE_NAME TMP_FILE_EDITOR

TMP_FILE_EDITOR="${TMP_FILE_EDITOR:-nvim}"

USER_TMP_DIR="${HOME}/tmp"
TMP_FILE_NAME="$1"

if [[ -z "$TMP_FILE_NAME" ]]; then
  echo "Must provide a filename"
  exit 1
fi

TMP_FILE_DATE="$(date +'%Y%m')"

TMP_FILE_PATH="${USER_TMP_DIR}/${TMP_FILE_DATE}"

if ! mkdir -p "${TMP_FILE_PATH}" 2>/dev/null; then
  echo "Could not create tmpfile directory"
  exit 1
fi

declare -r TMP_FILE="${TMP_FILE_PATH}/${TMP_FILE_NAME}"

unset USER_TMP_DIR TMP_FILE_NAME TMP_FILE_PATH

if ! touch "$TMP_FILE" 2>/dev/null; then
  echo "Could not create tmpfile"
  exit 1
fi

exec $TMP_FILE_EDITOR "$TMP_FILE"
