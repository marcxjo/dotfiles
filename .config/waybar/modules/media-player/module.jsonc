{
    "custom/icon#media-player": {
        "format": "󰝚",
        "tooltip": false
    },
    "mpris": {
        "format": "{player_icon} [{player}] {title}",
        "format-paused": "{status_icon} <i>[{player}] {title}</i>",
        "format-stopped": "{status_icon} {player}",
        "title-len": 32,
        "player-icons": {
            "default": "▶"
        },
        "status-icons": {
            "paused": "⏸",
            "stopped": ""
        }
    }
}
