{
  "clock#datetime": {
    "interval": 1,
    "format": "{:%a %b %d %Y | %X %Z}",
    "tooltip-format": "{tz_list}",
    "timezones": [
      "America/Denver",
      "America/Los_Angeles",
      "America/New_York",
      "UTC",
      "Australia/Sydney"
    ]
  },
  "custom/icon#datetime": {
    "format": "󰸗",
    "tooltip": false
  }
}
