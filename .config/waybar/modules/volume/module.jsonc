{
    "custom/icon#volume": {
        "format": "",
        "tooltip": false
    },
    "pulseaudio": {
        "scroll-step": 5,
        "max-volume": 100,
        "format": "{volume}%",
        "format-bluetooth": "[bt] {volume}%",
        "nospacing": 1,
        "on-click": "pavucontrol",
        "tooltip": false
    }
}
